<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AvatarBuilder.Modules.Webcam.DualCamera.DualCameraWorkspaceWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Avatar Builder - Dual Camera Workspace" Width="1640" Height="920" MinWidth="1180" MinHeight="700" Background="#080d12" Foreground="#f5f8fb" xmlns:dualcamera="clr-namespace:AvatarBuilder.Modules.Webcam.DualCamera;assembly=AvatarBuilder" Loaded="WindowLoaded" Closing="WindowClosing">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="PanelBrush" Color="#101820" />
      <SolidColorBrush x:Key="BorderBrush" Color="#243545" />
      <Style x:Key="{x:Type TextBlock}" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#f5f8fb" />
      </Style>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#142130" />
        <Setter Property="Foreground" Value="#f5f8fb" />
        <Setter Property="BorderBrush" Value="#37506a" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="MinHeight" Value="34" />
      </Style>
      <Style x:Key="{x:Type ToggleButton}" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="#142130" />
        <Setter Property="Foreground" Value="#f5f8fb" />
        <Setter Property="BorderBrush" Value="#37506a" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
          <Trigger Property="ToggleButton.IsChecked" Value="True">
            <Setter Property="Background" Value="#1f7a43" />
            <Setter Property="BorderBrush" Value="#52c47b" />
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="#0f1720" />
        <Setter Property="Foreground" Value="#f5f8fb" />
        <Setter Property="BorderBrush" Value="#37506a" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ComboBox}">
              <Grid>
                <ToggleButton Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="1" Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                  <Grid>
                    <ContentPresenter Margin="9,0,32,0" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{TemplateBinding ComboBox.SelectionBoxItem}" ContentTemplate="{TemplateBinding ComboBox.SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding ComboBox.SelectionBoxItemStringFormat}" TextElement.Foreground="{TemplateBinding Control.Foreground}" />
                    <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Fill="#f5f8fb" Data="M0,0 L4,4 L8,0" />
                  </Grid>
                </ToggleButton>
                <Popup Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding ComboBox.IsDropDownOpen}" Placement="Bottom">
                  <Border Background="#0f1720" BorderBrush="#d7e7f3" BorderThickness="1" MinWidth="{TemplateBinding FrameworkElement.ActualWidth}">
                    <ScrollViewer MaxHeight="320" CanContentScroll="True">
                      <ItemsPresenter />
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type ComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="#0f1720" />
        <Setter Property="Foreground" Value="#f5f8fb" />
        <Setter Property="Padding" Value="8,6" />
        <Style.Triggers>
          <Trigger Property="ComboBoxItem.IsHighlighted" Value="True">
            <Setter Property="Background" Value="#243f58" />
            <Setter Property="Foreground" Value="#ffffff" />
          </Trigger>
          <Trigger Property="ListBoxItem.IsSelected" Value="True">
            <Setter Property="Background" Value="#1d3348" />
            <Setter Property="Foreground" Value="#ffffff" />
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,10">
      <DockPanel>
        <TextBlock Text="Dual Camera Workspace" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        <TextBlock Name="WorkspaceStatusText" Text="Finding cameras..." Foreground="#8fd6ff" Margin="20,0,0,0" VerticalAlignment="Center" />
      </DockPanel>
    </Border>
    <Grid Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="#05090d" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Camera A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
              <ComboBox Name="CameraAComboBox" Grid.Column="1" MinWidth="180" SelectionChanged="CameraASelectionChanged" />
              <TextBlock Grid.Column="2" Text="Mode" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,8,0" />
              <ComboBox Name="ModeAComboBox" Grid.Column="3" MinWidth="190" SelectionChanged="ModeASelectionChanged" />
              <ToggleButton Name="CameraAToggle" Grid.Column="4" Width="100" Margin="10,0,0,0" Content="Camera Off" Checked="CameraAToggleChanged" Unchecked="CameraAToggleChanged" />
            </Grid>
          </Border>
          <Grid Name="CameraAPreviewPanel" Row="1" ClipToBounds="True">
            <Border Name="CameraAPlaceholder" Background="#020609">
              <TextBlock Name="CameraAPreviewStateText" Text="Camera off" Foreground="#7890a4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
            </Border>
          </Grid>
          <TextBlock Name="CameraAStatusText" Grid.Row="2" Text="Camera A ready." Background="#101820" Foreground="#8fd6ff" Padding="10,7" TextTrimming="CharacterEllipsis" />
        </Grid>
      </Border>
      <Border Grid.Column="2" Background="#05090d" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Camera B" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
              <ComboBox Name="CameraBComboBox" Grid.Column="1" MinWidth="180" SelectionChanged="CameraBSelectionChanged" />
              <TextBlock Grid.Column="2" Text="Mode" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,8,0" />
              <ComboBox Name="ModeBComboBox" Grid.Column="3" MinWidth="190" SelectionChanged="ModeBSelectionChanged" />
              <ToggleButton Name="CameraBToggle" Grid.Column="4" Width="100" Margin="10,0,0,0" Content="Camera Off" Checked="CameraBToggleChanged" Unchecked="CameraBToggleChanged" />
            </Grid>
          </Border>
          <Grid Name="CameraBPreviewPanel" Row="1" ClipToBounds="True">
            <Border Name="CameraBPlaceholder" Background="#020609">
              <TextBlock Name="CameraBPreviewStateText" Text="Camera off" Foreground="#7890a4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
            </Border>
          </Grid>
          <TextBlock Name="CameraBStatusText" Grid.Row="2" Text="Camera B ready." Background="#101820" Foreground="#8fd6ff" Padding="10,7" TextTrimming="CharacterEllipsis" />
        </Grid>
      </Border>
    </Grid>
    <Grid Row="2" Margin="0,10,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <ToggleButton Name="PhysicalCalibrationToggle" Grid.Column="0" Width="210" Content="Start Physical Calibration" Checked="PhysicalCalibrationToggleChanged" Unchecked="PhysicalCalibrationToggleChanged" />
      <TextBlock Name="CalibrationStatusText" Grid.Column="1" Margin="14,0" VerticalAlignment="Center" Foreground="#8fd6ff" Text="Printed target: 9 x 6 inner corners | 0.75-inch squares | 15 varied paired views" TextTrimming="CharacterEllipsis" />
      <ToggleButton Name="TranslationViewToggle" Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Width="210" Content="Coordinate Translation Off" Checked="TranslationViewToggleChanged" Unchecked="TranslationViewToggleChanged" />
      <TextBlock Name="TranslationStatusText" Grid.Row="1" Grid.Column="1" Margin="14,8,0,0" VerticalAlignment="Center" Foreground="#8fd6ff" Text="Own mesh: cyan | translated partner: amber | direct-view fusion: green" TextTrimming="CharacterEllipsis" />
      <ToggleButton Name="StereoReconstructionToggle" Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Width="210" Content="Build 3D Face" Checked="StereoReconstructionToggleChanged" Unchecked="StereoReconstructionToggleChanged" />
      <TextBlock Name="StereoReconstructionStatusText" Grid.Row="2" Grid.Column="1" Margin="14,8,0,0" VerticalAlignment="Center" Foreground="#80e0a4" Text="Log in to a profile and run both calibrated cameras to build its physical 3D face." TextTrimming="CharacterEllipsis" />
      <StackPanel Grid.Row="2" Grid.Column="2" Margin="10,8,0,0" Orientation="Horizontal">
        <Button Name="ViewStereoFaceButton" Width="150" Content="View 3D Face" IsEnabled="False" Click="ViewStereoFaceClicked" />
        <Button Name="ViewRawStereoPointsButton" Margin="8,0,0,0" Width="150" Content="View Raw Points" IsEnabled="False" Click="ViewRawStereoPointsClicked" />
        <Button Name="ViewProbabilityFaceButton" Margin="8,0,0,0" Width="170" Content="View Probability Face" IsEnabled="False" Click="ViewProbabilityFaceClicked" />
      </StackPanel>
      <Button Grid.RowSpan="3" Grid.Column="3" Margin="10,0,0,0" Content="Close" Width="110" Click="CloseClicked" />
    </Grid>
  </Grid>
</Window>