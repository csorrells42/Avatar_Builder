<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <LangVersion>preview</LangVersion>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NuGetAudit>false</NuGetAudit>
    <AssemblyName>AvatarBuilder</AssemblyName>
    <Product>Avatar Builder</Product>
    <AssemblyTitle>Avatar Builder</AssemblyTitle>
    <Description>Standalone camera-based 3D avatar capture and reconstruction application.</Description>
    <DesktopRuntimeDirectory>$(MSBuildProjectDirectory)\desktop-runtime</DesktopRuntimeDirectory>
    <DesktopRuntimeManifest>$(DesktopRuntimeDirectory)\.build-manifest.txt</DesktopRuntimeManifest>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tools\**\*.cs" />
    <Content
      Include="dependencies\**\*"
      Exclude="dependencies\**\__pycache__\**\*;dependencies\**\*.pyc;dependencies\**\.git\**\*" >
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Include="Modules\Vision\MediaPipe\Sidecar\*.py;Modules\Vision\MediaPipe\Sidecar\requirements.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Include="Modules\Vision\Onnx\Sidecar\*.py">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.0" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.12" />
    <PackageReference Include="OpenCvSharp4" Version="4.13.0.20260602" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.13.0.20260602" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.24.4" />
    <PackageReference Include="Vortice.D3DCompiler" Version="3.8.3" />
    <PackageReference Include="Vortice.Direct2D1" Version="3.8.3" />
    <PackageReference Include="Vortice.Direct3D11" Version="3.8.3" />
    <PackageReference Include="Vortice.Direct3D12" Version="3.8.3" />
  </ItemGroup>

  <Target Name="UpdateDesktopRuntime" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <ItemGroup>
      <CurrentDesktopRuntimeFile
        Include="$(TargetDir)**\*"
        Exclude="$(TargetDir)AvatarBuilderOutputFolder.txt;$(TargetDir)AvatarBuilder-startup.log;$(TargetDir)AvatarBuilderSessions\**\*;$(TargetDir)output\**\*" />
      <CurrentDesktopRuntimeDestination
        Include="@(CurrentDesktopRuntimeFile->'$(DesktopRuntimeDirectory)\%(RecursiveDir)%(Filename)%(Extension)')" />
      <ExistingDesktopRuntimeFile
        Include="$(DesktopRuntimeDirectory)\**\*"
        Exclude="$(DesktopRuntimeManifest);$(DesktopRuntimeDirectory)\AvatarBuilderOutputFolder.txt;$(DesktopRuntimeDirectory)\AvatarBuilder-startup.log;$(DesktopRuntimeDirectory)\AvatarBuilderSessions\**\*;$(DesktopRuntimeDirectory)\output\**\*" />
      <StaleDesktopRuntimeFile
        Include="@(ExistingDesktopRuntimeFile)"
        Exclude="@(CurrentDesktopRuntimeDestination)" />
    </ItemGroup>
    <MakeDir Directories="$(DesktopRuntimeDirectory)" />
    <Delete Files="@(StaleDesktopRuntimeFile)" />
    <Copy
      SourceFiles="@(CurrentDesktopRuntimeFile)"
      DestinationFiles="@(CurrentDesktopRuntimeDestination)"
      SkipUnchangedFiles="true" />
    <WriteLinesToFile
      File="$(DesktopRuntimeManifest)"
      Lines="@(CurrentDesktopRuntimeFile->'$(DesktopRuntimeDirectory)\%(RecursiveDir)%(Filename)%(Extension)')"
      Overwrite="true" />
    <Message Importance="high" Text="Avatar Builder desktop runtime updated: $(DesktopRuntimeDirectory)" />
  </Target>

</Project>
