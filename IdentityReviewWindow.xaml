<Window x:Class="AvatarBuilder.IdentityReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Identity Review"
        Width="980"
        Height="680"
        MinWidth="820"
        MinHeight="560"
        Background="#080d12"
        Foreground="#f5f8fb"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#f5f8fb" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#142130" />
      <Setter Property="Foreground" Value="#f5f8fb" />
      <Setter Property="BorderBrush" Value="#37506a" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#0f1720" />
      <Setter Property="Foreground" Value="#f5f8fb" />
      <Setter Property="CaretBrush" Value="#f5f8fb" />
      <Setter Property="BorderBrush" Value="#37506a" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#0f1720" />
      <Setter Property="Foreground" Value="#f5f8fb" />
      <Setter Property="BorderBrush" Value="#37506a" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Identity Review"
                 FontSize="24"
                 FontWeight="Bold" />
      <TextBlock Margin="0,4,0,14"
                 Foreground="#b9d7ef"
                 Text="Name retained people and optionally register them for the Ali testbed. Face recognition identifies a record; it does not authenticate permissions." />
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="310" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Background="#101820"
              BorderBrush="#243545"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Text="Learned people"
                     FontWeight="SemiBold"
                     Margin="2,0,0,8" />
          <ListBox Name="IdentityList"
                   Grid.Row="1"
                   Background="#0b1219"
                   Foreground="#f5f8fb"
                   BorderBrush="#243545"
                   SelectionChanged="IdentitySelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4,5">
                  <TextBlock Text="{Binding DisplayName}"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding PermissionLevel}"
                             Foreground="#80e0a4"
                             FontSize="12" />
                  <TextBlock Text="{Binding LastSeenAtUtc, StringFormat='Last seen {0:g}'}"
                             Foreground="#8ea8bc"
                             FontSize="11" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              Background="#101820"
              BorderBrush="#243545"
              BorderThickness="1"
              CornerRadius="5"
              Padding="16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="18" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Background="#05090d"
                    BorderBrush="#37506a"
                    BorderThickness="1">
              <Grid>
                <Image Name="ContextPhoto"
                       Stretch="Uniform" />
                <TextBlock Name="NoPhotoText"
                           Text="No context photo is available yet."
                           Foreground="#8ea8bc"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
              </Grid>
            </Border>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Name" FontWeight="SemiBold" />
              <TextBox Name="DisplayNameTextBox"
                       Margin="0,5,0,14" />
              <CheckBox Name="RegisterAsUserCheckBox"
                        Content="Register as user"
                        Foreground="#f5f8fb"
                        Checked="RegistrationChanged"
                        Unchecked="RegistrationChanged" />
              <TextBlock Text="Permission level"
                         Margin="0,14,0,5"
                         FontWeight="SemiBold" />
              <ComboBox Name="PermissionLevelComboBox">
                <ComboBoxItem Content="Default User" />
                <ComboBoxItem Content="Superuser" />
              </ComboBox>
              <TextBlock Name="IdentityDetailText"
                         Margin="0,18,0,0"
                         Foreground="#b9d7ef"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,14,0,0"
                         Foreground="#f0c96d"
                         TextWrapping="Wrap"
                         Text="Superuser is a test/recovery label here. Avatar Builder does not enforce permissions, and Ali must require an independent owner recovery credential." />
            </StackPanel>
          </Grid>
          <StackPanel Grid.Row="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Margin="0,16,0,0">
            <Button Content="Refresh"
                    Click="RefreshClicked"
                    Margin="0,0,8,0" />
            <Button Content="Save identity"
                    Click="SaveIdentityClicked"
                    Margin="0,0,8,0" />
            <Button Content="Close"
                    Click="CloseClicked" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <TextBlock Name="StatusText"
               Grid.Row="2"
               Margin="0,12,0,0"
               Foreground="#80e0a4"
               TextWrapping="Wrap" />
  </Grid>
</Window>
