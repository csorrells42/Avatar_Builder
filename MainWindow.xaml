<Window x:Class="EpisodeMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Episode Monitor"
        MinHeight="720"
        MinWidth="1100"
        Height="820"
        Width="1280"
        Background="#080d12"
        Foreground="#f5f8fb"
        Loaded="WindowLoaded"
        Closing="WindowClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101820" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#0c1218" />
        <SolidColorBrush x:Key="BorderBrush" Color="#243545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f5f8fb" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#142130" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type Button}}" />

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0c1218" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#243545" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#0c1218" />
            <Setter Property="AlternatingRowBackground" Value="#101820" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1d2c38" />
            <Setter Property="VerticalGridLinesBrush" Value="#1d2c38" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182532" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#2b4054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Camera" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraComboBox" Grid.Column="1" SelectionChanged="CameraSelectionChanged" />
                <TextBlock Grid.Column="2" Text="Mode" VerticalAlignment="Center" Margin="14,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraModeComboBox" Grid.Column="3" SelectionChanged="CameraModeSelectionChanged" />
                <ToggleButton x:Name="CameraToggle" Grid.Column="4" Margin="14,0,0,0" Content="Camera Off" Checked="CameraToggleChanged" Unchecked="CameraToggleChanged" />
                <Button Grid.Column="5" Margin="8,0,0,0" Content="Refresh" Click="RefreshCamerasClicked" />
                <TextBlock x:Name="TopStatusText" Grid.Column="6" Text="Ready." VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#b9d7ef" />
                <Button Grid.Column="7" Content="Close" Click="CloseClicked" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="0" Background="#05080c" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                    <StackPanel x:Name="PreviewPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Episode Monitor" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewStateText" Text="Camera disabled" Margin="0,10,0,0" Foreground="#b9d7ef" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" Margin="14,0,0,0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Episode Watch" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Logs observable sustained low-motion events for review. This does not diagnose a medical condition." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,8" />

                        <CheckBox x:Name="WatchEnabledCheckBox" Content="Enable possible-sleep episode watch" Checked="WatchEnabledChanged" Unchecked="WatchEnabledChanged" />
                        <CheckBox x:Name="SnapshotCheckBox" Content="Save snapshots at episode start and end" IsChecked="True" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Low-motion threshold" FontWeight="SemiBold" />
                            <TextBlock x:Name="ThresholdValueText" Grid.Column="1" Text="1.5%" Foreground="#b9d7ef" />
                        </Grid>
                        <Slider x:Name="ThresholdSlider" Minimum="0.2" Maximum="8" Value="1.5" TickFrequency="0.1" ValueChanged="SettingChanged" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stillness time" FontWeight="SemiBold" />
                            <TextBlock x:Name="StillnessValueText" Grid.Column="1" Text="120s" Foreground="#b9d7ef" />
                        </Grid>
                        <Slider x:Name="StillnessSlider" Minimum="15" Maximum="900" Value="120" TickFrequency="15" IsSnapToTickEnabled="True" ValueChanged="SettingChanged" />

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Content="Mark Now" Click="MarkNowClicked" />
                            <Button Content="Export CSV" Margin="8,0,0,0" Click="ExportClicked" />
                            <Button Content="Clear" Margin="8,0,0,0" Click="ClearClicked" />
                        </StackPanel>

                        <TextBlock x:Name="MonitorStatusText" Text="Episode monitor idle." TextWrapping="Wrap" Margin="0,16,0,0" Foreground="#b9d7ef" />

                        <Separator Margin="0,18,0,18" Background="#243545" />

                        <TextBlock Text="Output" FontSize="18" FontWeight="Bold" />
                        <TextBlock x:Name="OutputFolderText" TextWrapping="Wrap" Foreground="#b9d7ef" Margin="0,8,0,0" />
                        <Button Content="Choose Folder" HorizontalAlignment="Left" Margin="0,8,0,0" Click="BrowseOutputClicked" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,14,0,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DataGrid x:Name="EventGrid" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Started" Binding="{Binding StartLabel}" Width="150" />
                        <DataGridTextColumn Header="Ended" Binding="{Binding EndLabel}" Width="150" />
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="95" />
                        <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="180" />
                        <DataGridTextColumn Header="Avg Motion" Binding="{Binding AvgMotion}" Width="110" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="240" />
                        <DataGridTextColumn Header="Files" Binding="{Binding File}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <TextBlock x:Name="FooterText" Grid.Row="2" Text="Ready." Foreground="#b9d7ef" />
    </Grid>
</Window>
