<Window x:Class="AvatarBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Avatar Builder"
        MinHeight="720"
        MinWidth="1100"
        Height="820"
        Width="1280"
        Background="#080d12"
        Foreground="#f5f8fb"
        Loaded="WindowLoaded"
        Closing="WindowClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101820" />
        <SolidColorBrush x:Key="BorderBrush" Color="#243545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f5f8fb" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#101820" />
            <Setter Property="Foreground" Value="#f5f8fb" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="MenuItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="CheckColumn" Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CheckIndicator"
                                               Grid.Column="0"
                                               Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#8ee6b5"
                                               Visibility="Collapsed"
                                               VerticalAlignment="Center" />
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="SubmenuIndicator"
                                               Grid.Column="2"
                                               Text="&#xE76C;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#b9d7ef"
                                               Visibility="Collapsed"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade">
                                <Border Background="#101820"
                                        BorderBrush="#37506a"
                                        BorderThickness="1"
                                        MinWidth="170"
                                        Padding="2">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#243f58" />
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="#4c7598" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#183149" />
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="#4c7598" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="IsCheckable" Value="False">
                                <Setter TargetName="CheckColumn" Property="Width" Value="0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#142130" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="StartStopButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#142130" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter Margin="9,0,32,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <Path HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Fill="#f5f8fb"
                                          Data="M 0 0 L 4 4 L 8 0 Z" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#0f1720"
                                        BorderBrush="#d7e7f3"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="320" CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#6b92b6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#243f58" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1d3348" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="#f5f8fb" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Background" Value="#101820" />
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,8">
            <MenuItem Header="_File">
                <MenuItem x:Name="LoginLogoutMenuItem" Header="_Login..." Click="LoginLogoutClicked" />
                <MenuItem Header="_Choose Data Folder..." Click="OpenDataFolderClicked" />
                <MenuItem Header="_Face Box System">
                    <MenuItem x:Name="MediaPipeFaceBoxSystemMenuItem"
                              Header="_MediaPipe"
                              IsCheckable="True"
                              IsChecked="True"
                              Tag="MediaPipe"
                              Click="FaceBoxSystemMenuItemClicked" />
                    <MenuItem x:Name="ThreeDdfaFaceBoxSystemMenuItem"
                              Header="_3DDFA-V2"
                              IsCheckable="True"
                              Tag="ThreeDdfaV2"
                              Click="FaceBoxSystemMenuItemClicked" />
                </MenuItem>
                <MenuItem Header="E_xit" Click="CloseClicked" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="DirectX12PreviewMenuItem"
                          Header="_DX12 Preview Viewport"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="DirectX12PreviewMenuItemClicked" />
                <MenuItem x:Name="LiveWireframeMenuItem"
                          Header="Show Live _Wireframe"
                          IsCheckable="True"
                          ToolTip="Hides the webcam image and shows the current camera-relative MediaPipe face mesh while analysis keeps running."
                          Click="LiveWireframeMenuItemClicked" />
                <MenuItem Header="A/B/C _Alignment Audit"
                          ToolTip="Opens the exact-frame MediaPipe versus 3DDFA pose agreement report."
                          Click="OpenPoseAlignmentAuditClicked" />
                <MenuItem Header="_Tracking Fidelity">
                    <MenuItem x:Name="TrackingFidelity4KMenuItem"
                              Header="_4K - 3840 camera / 1920 analysis / 15 fps"
                              IsCheckable="True"
                              IsChecked="True"
                              Tag="2"
                              Click="TrackingFidelityMenuItemClicked" />
                    <MenuItem x:Name="TrackingFidelityHdMenuItem"
                              Header="_HD - 1920 analysis / 18 fps"
                              IsCheckable="True"
                              Tag="1"
                              Click="TrackingFidelityMenuItemClicked" />
                    <MenuItem x:Name="TrackingFidelitySafeMenuItem"
                              Header="_Safe Preview - 960 analysis / 15 fps"
                              IsCheckable="True"
                              Tag="0"
                              Click="TrackingFidelityMenuItemClicked" />
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Camera" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraComboBox" Grid.Column="1" SelectionChanged="CameraSelectionChanged" />
                <TextBlock Grid.Column="2" Text="Mode" VerticalAlignment="Center" Margin="14,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraModeComboBox" Grid.Column="3" SelectionChanged="CameraModeSelectionChanged" />
                <ToggleButton x:Name="CameraToggle" Grid.Column="4" Margin="14,0,0,0" Content="Camera Off" Checked="CameraToggleChanged" Unchecked="CameraToggleChanged" />
                <Button Grid.Column="5" Margin="8,0,0,0" Content="Refresh" Click="RefreshCamerasClicked" />
                <TextBlock x:Name="TopStatusText" Grid.Column="6" Text="Ready." VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#b9d7ef" />
                <Button Grid.Column="7" Content="Close" Click="CloseClicked" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#05080c" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid x:Name="PreviewHost" SizeChanged="PreviewHostSizeChanged">
                    <Grid x:Name="DirectX12PreviewLayer" Visibility="Collapsed" ClipToBounds="True" />
                    <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                    <Canvas x:Name="LiveWireframeCanvas" Visibility="Collapsed" ClipToBounds="True" Background="#05080c" />
                    <Canvas x:Name="FaceCueGuideCanvas" IsHitTestVisible="False" />
                    <StackPanel x:Name="PreviewPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Avatar Builder" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewStateText" Text="Camera disabled" Margin="0,10,0,0" Foreground="#b9d7ef" HorizontalAlignment="Center" />
                    </StackPanel>
                    <Border x:Name="TrackingOverlay" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14" Background="#d8080d12" BorderBrush="#37506a" BorderThickness="1" Padding="10" MinWidth="360" MaxWidth="860">
                        <StackPanel>
                            <TextBlock x:Name="OverlayStateText" Text="Avatar tracking idle" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock x:Name="OverlayMetricText" Text="Face lock -- | eye -- | mouth --" Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <TextBlock x:Name="OverlayTriggerText" Text="Turn on the camera to begin face tracking." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="14,0,0,0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,18,0">
                        <Border Background="#0c1218" BorderBrush="#243545" BorderThickness="1" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Avatar Building" FontSize="20" FontWeight="Bold" />
                                <TextBlock Text="Captures 3DDFA face reconstruction data while keeping live eye, jaw, and brow tracking available for review." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,8" />

                                <TextBlock x:Name="AvatarLoginStatusText" Text="No avatar user logged in. Use File > Login to begin a capture session." Foreground="#ffcf7a" TextWrapping="Wrap" Margin="0,4,0,0" />

                                <Border Background="#081018" BorderBrush="#243545" BorderThickness="1" Padding="10" Margin="0,10,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="AvatarLearningIndicator" Width="11" Height="11" CornerRadius="6" Background="#59616b" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock x:Name="AvatarLearningStateText" Grid.Column="1" Text="Avatar capture stopped" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button x:Name="AvatarLearningToggleButton" Grid.Column="2" Style="{StaticResource StartStopButtonStyle}" Content="Start Avatar Capture" ToolTip="Log in an avatar user before starting 3DDFA avatar capture." Padding="10,6" Margin="8,0,0,0" IsEnabled="False" Click="AvatarLearningToggleClicked" />
                                        </Grid>
                                        <TextBlock x:Name="AvatarLearningStatusText" Text="Not capturing: log in the person in front of the camera, then start avatar capture." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        <TextBlock x:Name="AvatarTrackingSanityText" Text="Tracking sanity: waiting for enough accepted measurements." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <TextBlock x:Name="AvatarReconstructionLaneText" Text="Avatar reconstruction: 3DDFA/ONNX waiting." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <Border Background="#0b141c" BorderBrush="#243545" BorderThickness="1" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock x:Name="AvatarCaptureGuidanceTitleText" Text="Capture Guidance" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock x:Name="AvatarCaptureGuidanceDetailText" Text="Log in the person in front of the camera, start the camera, then use Start Avatar Capture when you want 3DDFA samples collected." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <UniformGrid Columns="2" Margin="0,10,0,0">
                                            <Button Content="Open Avatar System" ToolTip="Opens one combined page for 3DDFA reconstruction, live tracking review, stored avatar data, and next capture guidance." Margin="0,0,6,0" Click="OpenAvatarSystemClicked" />
                                            <Button Content="Open 3DDFA Last 5" ToolTip="Opens the separate dense 3DDFA reconstruction viewer for the last five avatar samples." Margin="6,0,0,0" Click="OpenLastGoodThreeDdfaClicked" />
                                            <Button Content="Open Avatar Model Progress" ToolTip="Opens the accumulated 3DDFA identity and expression model viewer." Margin="0,8,6,0" Click="OpenAvatarModelProgressClicked" />
                                            <Button x:Name="RebuildAvatarDataButton" Content="Rebuild Avatar Data" ToolTip="Archives the current Avatar data and starts fresh review/capture files." Margin="6,8,0,0" Click="RebuildAvatarDataClicked" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <Expander x:Name="FaceTrackingFieldExpander" Header="Face Box Options (MediaPipe)" IsExpanded="False">
                                    <StackPanel Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field horizontal" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldXValueText" Grid.Column="1" Text="50%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldXSlider" Minimum="20" Maximum="80" Value="50" TickPlacement="BottomRight" Ticks="50" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field vertical" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldYValueText" Grid.Column="1" Text="48%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldYSlider" Minimum="20" Maximum="80" Value="48" TickPlacement="BottomRight" Ticks="48" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field size" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldSizeValueText" Grid.Column="1" Text="60%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldSizeSlider" Minimum="25" Maximum="90" Value="60" TickPlacement="BottomRight" Ticks="60" ValueChanged="SettingChanged" />
                                        <CheckBox x:Name="FaceAutoFollowCheckBox" Content="Auto-follow face field" IsChecked="True" Checked="FaceTrackingFieldChanged" Unchecked="FaceTrackingFieldChanged" />
                                    </StackPanel>
                                </Expander>

                                <TextBlock x:Name="MonitorStatusText" Text="Avatar tracking idle." TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#b9d7ef" />

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <Expander Header="Camera Controls" IsExpanded="False">
                                    <StackPanel Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Camera Controls" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="Refresh" Padding="10,6" MinHeight="30" Click="RefreshCameraControlsClicked" />
                                        </Grid>
                                        <TextBlock x:Name="CameraControlsStatusText" Text="Choose a camera to load controls." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        <StackPanel x:Name="CameraControlsPanel" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <TextBlock x:Name="FooterText" Grid.Row="3" Text="Ready." Foreground="#b9d7ef" />
    </Grid>
</Window>
